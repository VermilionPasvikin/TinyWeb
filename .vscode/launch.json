{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(lldb) 启动 TinyWeb",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/TinyWeb",
            "args": ["100", "--admin-port", "9090"],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": true,
            "MIMode": "lldb"
        },

        {
            "name": "(lldb) 启动 TinyProxy",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/TinyProxy",
            "args": [
                "80", "--admin-port", "9091", "localhost:100", "localhost:101", "localhost:102", "localhost:103"
            ],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": true,
            "MIMode": "lldb"
        }
    ]
}